<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:background="@drawable/bg_installer_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/badge_chip"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="ELITE XENO INSTALLER"
            android:textColor="#AEEBFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/logo_glow" />

            <ImageView
                android:id="@+id/logoView"
                android:layout_width="218dp"
                android:layout_height="218dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="Elite Xeno logo"
                android:src="@drawable/app_logo" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="ELITE XENO"
            android:textColor="#F3F7FF"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center"
            android:text="Semi-Autonomous Device Intelligence"
            android:textColor="#32D4FF"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="v1.0"
            android:textColor="#89A9C7"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/aboutPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_surface_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What Is Elite Xeno"
                android:textAllCaps="true"
                android:textColor="#66D7FF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="5dp"
                android:text="Elite Xeno is an advanced on-device intelligence layer that observes, decides, and executes actions to maximize your device's performance, customization, and responsiveness — all while keeping you in full control."
                android:textColor="#DCE8F7"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="5dp"
                android:text="Powered by a hybrid AI engine that works both online and offline, with smart automation, game boosting, predictive actions, and deep system control through Shizuku, Accessibility, and optional root access."
                android:textColor="#C6DBF4"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/capabilitiesPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_surface_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capabilities"
                android:textAllCaps="true"
                android:textColor="#66D7FF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:text="Hybrid AI — online + offline intelligence&#10;Performance Engine — 4 modes + custom profiles&#10;Game Center — per-game boost + auto-detect&#10;Smart Automation — battery, RAM, app triggers&#10;Predictive Engine — suggest actions before asking&#10;Accessibility + Shizuku + Root — deep device control&#10;Command Center — full system visibility + real-time logs&#10;AI Personality — Minimal / Assistant / Pro modes"
                android:textColor="#DCE8F7"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/installPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_surface_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install Status"
                android:textAllCaps="true"
                android:textColor="#66D7FF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Ready to install"
                android:textColor="#EAF2FF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ProgressBar
                    android:id="@+id/installProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="12dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_install" />

                <TextView
                    android:id="@+id/percentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="0%"
                    android:textColor="#7AD9FF"
                        android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/installButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_install"
                android:text="INSTALL ELITE XENO"
                android:textAllCaps="false"
                android:textColor="#021220"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/compliancePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_surface_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Compliance &amp; Privacy"
                android:textAllCaps="true"
                android:textColor="#66D7FF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="This app requests package install permission only to install your selected payload and requires your explicit confirmation on the Android system installer screen."
                android:textColor="#C6DBF4"
                android:textSize="14sp" />

            <Button
                android:id="@+id/complianceButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_social"
                android:text="View Compliance Details"
                android:textAllCaps="false"
                android:textColor="#CFF4FF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/creditsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/panel_surface_premium"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Creator Credits"
                android:textAllCaps="true"
                android:textColor="#66D7FF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/instagramButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_social"
                    android:text="Instagram"
                    android:textAllCaps="false"
                    android:textColor="#CFF4FF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/githubButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_social"
                    android:text="GitHub"
                    android:textAllCaps="false"
                    android:textColor="#CFF4FF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
