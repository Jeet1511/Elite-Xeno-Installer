<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1D3850" />
            <stroke android:width="1dp" android:color="#58DFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:startColor="#172941"
                android:endColor="#111E34" />
            <stroke android:width="1dp" android:color="#2C86AA" />
        </shape>
    </item>
</selector>
